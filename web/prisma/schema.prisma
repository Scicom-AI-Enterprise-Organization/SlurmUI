generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SshKey {
  id         String    @id @default(uuid())
  name       String    @unique
  privateKey String    @db.Text
  publicKey  String    @db.Text
  createdAt  DateTime  @default(now())
  clusters   Cluster[]
}

model Cluster {
  id              String         @id @default(uuid())
  name            String         @unique
  controllerHost  String
  connectionMode  ConnectionMode @default(NATS)
  natsUrl         String?        // NATS URL the agent uses to connect back (NATS mode only)
  natsCredentials String         // encrypted at rest
  sshUser         String         @default("root")
  sshPort         Int            @default(22)
  sshBastion      Boolean        @default(false) // true if SSH host is a bastion/jump server (interactive-shell mode)
  // Separate ProxyJump (ssh -J) hop. When sshJumpHost is set, every SSH call
  // routes through this host first, then connects to controllerHost. Reuses
  // the cluster's main sshKey for both hops.
  sshJumpHost     String?
  sshJumpUser     String?        @default("root")
  sshJumpPort     Int?           @default(22)
  // Optional separate SSH key for the jump hop. No Prisma relation to keep
  // the main `sshKey` include-path unchanged across dozens of call sites;
  // we fetch this key by ID on demand inside ssh-exec helpers.
  sshJumpKeyId    String?
  // Raw -o ProxyCommand override for the primary ssh hop (to controller).
  // When set, ssh reaches the controller via this command — the jump
  // fields are ignored.
  sshProxyCommand     String?    @db.Text
  // Raw -o ProxyCommand override for the jumphost hop. Used when the
  // jumphost itself is reached via a non-ssh transport (e.g. cloudflared
  // access tcp). Nested inside the jump-W ssh.
  sshJumpProxyCommand String?    @db.Text
  status          ClusterStatus  @default(PROVISIONING)
  config          Json           // full cluster-config.json
  sshKeyId              String?
  sshKey                SshKey?       @relation(fields: [sshKeyId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  installToken          String?       @unique
  installTokenExpiresAt DateTime?
  installTokenUsedAt    DateTime?
  jobs                  Job[]
  clusterUsers          ClusterUser[]
  appSessions           AppSession[]
  jobTemplates          JobTemplate[]
}

enum ConnectionMode {
  NATS
  SSH
}

enum ClusterStatus {
  PROVISIONING
  ACTIVE
  DEGRADED
  OFFLINE
}

model Job {
  id         String    @id @default(uuid())
  slurmJobId Int?
  clusterId  String
  cluster    Cluster   @relation(fields: [clusterId], references: [id])
  userId     String
  script     String
  partition  String
  // Stable user-supplied job name — sourced from the script's
  // `#SBATCH --job-name=` directive on submit. Enforced unique across
  // PENDING/RUNNING jobs in a cluster *in code* (see lib/submit-job.ts);
  // we keep the column nullable + non-unique at the DB level so legacy
  // rows with duplicate names don't block schema migration. The
  // `(clusterId, name)` index below is what makes the in-code uniqueness
  // check fast.
  name       String?
  status     JobStatus @default(PENDING)
  exitCode   Int?
  output     String?   @db.Text
  // GitOps tracking. Populated only when the job was submitted via the
  // gitops reconciler. `sourceName` is metadata.name from the manifest and
  // is unique per cluster so a single manifest maps to a single job lineage;
  // `sourceRef` is "<repo-rel-path>@<sha256(content)>" so the reconciler
  // can detect content changes and skip / cancel-resubmit accordingly.
  sourceRef  String?
  sourceName String?
  // When set, Aura tells Prometheus to scrape <jobNode>:<metricsPort>/metrics
  // for every node the job runs on. Used for vLLM and similar services that
  // expose Prometheus metrics on a known port. Refreshed via
  // /api/clusters/[id]/metrics/refresh-targets after status changes.
  metricsPort Int?
  // When set, the web server reverse-proxies HTTP+WebSocket traffic from
  // /job-proxy/<clusterId>/<jobId>/* to <jobNode>:<proxyPort>/*. Generic —
  // works for Jupyter, TensorBoard, MLflow, FastAPI, anything that speaks
  // HTTP/WS on a known port. proxyName is a free-form label shown on the
  // cluster Proxies tab (e.g. "Jupyter", "TensorBoard").
  proxyPort   Int?
  proxyName   String?
  // When true, anyone with the /job-proxy/<clusterId>/<jobId>/* URL can
  // hit the proxy without an Aura session — used for sharing a notebook /
  // demo / dashboard with people who don't have accounts. Off by default;
  // the URL is unguessable enough to be safe with this opt-in.
  proxyPublic Boolean @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([clusterId])
  @@index([userId])
  @@index([status])
  // Cover the listing endpoint's `WHERE clusterId=? [AND userId=?] ORDER BY
  // createdAt DESC LIMIT N` query — without this Postgres has to filter via
  // the single-col clusterId index then sort the matching rows in memory,
  // which dominates page-load time on clusters with thousands of jobs.
  @@index([clusterId, createdAt])
  @@index([clusterId, userId, createdAt])
  @@index([clusterId, name])
  @@unique([clusterId, sourceName])
}

model JobTemplate {
  id          String   @id @default(uuid())
  clusterId   String
  cluster     Cluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  script      String   @db.Text
  partition   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clusterId])
  @@index([userId])
  @@unique([clusterId, userId, name])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id            String        @id @default(uuid())
  // Keycloak-backed users get the OIDC sub here; locally-credentialled
  // users get `local:<uuid>` so the unique index still holds.
  keycloakId    String        @unique
  email         String        @unique
  name          String?
  // bcrypt hash. Null = Keycloak-only user, login via Credentials blocked.
  passwordHash  String?
  // Proof the email belongs to this user. Set to now() on invite acceptance
  // since clicking the single-use invite link proves control of the inbox.
  emailVerified DateTime?
  unixUid       Int?          @unique
  unixGid       Int?
  unixUsername  String?       @unique
  role          UserRole      @default(VIEWER)
  createdAt     DateTime      @default(now())
  clusters      ClusterUser[]
  appSessions   AppSession[]
  jobTemplates  JobTemplate[]
  invitesCreated Invite[]     @relation("InviteCreator")
  passwordResets PasswordResetToken[]
  apiTokens      ApiToken[]
}

// Personal API token for the /api/v1 endpoints. The raw token is shown to
// the user once at creation time (`aura_<32-bytes>`-ish); only the sha256
// digest is stored, same pattern as GitHub PATs and our Invite table.
model ApiToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String    // human label shown in /profile/api-tokens
  tokenHash  String    @unique // sha256(rawToken)
  prefix     String    // first 8 chars of the raw token, for the list UI
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([userId])
  @@index([revokedAt])
}

model AppSession {
  id          String   @id @default(uuid())
  clusterId   String
  userId      String
  type        String   // "shell" | "jupyter"
  partition   String
  status      String   @default("STARTING") // STARTING | RUNNING | STOPPED | FAILED
  accessUrl   String?  // Jupyter token URL
  createdAt   DateTime @default(now())
  cluster     Cluster  @relation(fields: [clusterId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([clusterId])
  @@index([userId])
}

enum UserRole {
  ADMIN
  USER
  VIEWER
}

// Single-use password reset token. Admin-initiated only (no self-serve
// "forgot password" flow yet) — admin generates a link, user opens it and
// sets a new password. Expires fast since it short-circuits auth.
model PasswordResetToken {
  id          String    @id @default(uuid())
  token       String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdById String    // admin who issued the link
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Single-use signup invitation. Admins generate these from the organization
// page; accepting the link creates a User with the baked-in role. Tokens are
// 32 random bytes base64url-encoded and never round-tripped except via the
// copy-once-on-creation dialog.
model Invite {
  id           String    @id @default(uuid())
  token        String    @unique
  // Optional email lock. When set, the public accept page pre-fills this
  // value and the server rejects any other address.
  email        String?
  role         UserRole
  createdById  String
  createdBy    User      @relation("InviteCreator", fields: [createdById], references: [id])
  expiresAt    DateTime
  usedAt       DateTime?
  usedByUserId String?
  createdAt    DateTime  @default(now())

  @@index([createdById])
  @@index([expiresAt])
}

model ClusterUser {
  id            String            @id @default(uuid())
  userId        String
  clusterId     String
  status        ClusterUserStatus @default(PENDING)
  provisionedAt DateTime?
  user          User              @relation(fields: [userId], references: [id])
  cluster       Cluster           @relation(fields: [clusterId], references: [id])

  @@unique([userId, clusterId])
  @@index([clusterId])
}

enum ClusterUserStatus {
  PENDING
  ACTIVE
  FAILED
  REMOVED
}

// Global key-value settings store (admin-managed).
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model BackgroundTask {
  id          String   @id @default(uuid())
  clusterId   String
  type        String   // "bootstrap", "teardown", "add_node", etc.
  status      String   @default("running") // "running", "success", "failed"
  logs        String   @db.Text @default("")
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([clusterId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "cluster.create", "ssh_key.delete", "user.provision"
  entity    String   // e.g. "Cluster", "SshKey", "User"
  entityId  String?  // ID of the affected entity
  userId    String?  // who performed the action
  userEmail String?  // denormalized for display
  metadata  Json?    // extra context (cluster name, old/new values, etc.)
  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
