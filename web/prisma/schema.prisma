generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SshKey {
  id         String    @id @default(uuid())
  name       String    @unique
  privateKey String    @db.Text
  publicKey  String    @db.Text
  createdAt  DateTime  @default(now())
  clusters   Cluster[]
}

model Cluster {
  id              String         @id @default(uuid())
  name            String         @unique
  controllerHost  String
  connectionMode  ConnectionMode @default(NATS)
  natsUrl         String?        // NATS URL the agent uses to connect back (NATS mode only)
  natsCredentials String         // encrypted at rest
  sshUser         String         @default("root")
  sshPort         Int            @default(22)
  status          ClusterStatus  @default(PROVISIONING)
  config          Json           // full cluster-config.json
  sshKeyId              String?
  sshKey                SshKey?       @relation(fields: [sshKeyId], references: [id])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  installToken          String?       @unique
  installTokenExpiresAt DateTime?
  installTokenUsedAt    DateTime?
  jobs                  Job[]
  clusterUsers          ClusterUser[]
  appSessions           AppSession[]
}

enum ConnectionMode {
  NATS
  SSH
}

enum ClusterStatus {
  PROVISIONING
  ACTIVE
  DEGRADED
  OFFLINE
}

model Job {
  id         String    @id @default(uuid())
  slurmJobId Int?
  clusterId  String
  cluster    Cluster   @relation(fields: [clusterId], references: [id])
  userId     String
  script     String
  partition  String
  status     JobStatus @default(PENDING)
  exitCode   Int?
  output     String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([clusterId])
  @@index([userId])
  @@index([status])
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model User {
  id            String        @id @default(uuid())
  keycloakId    String        @unique
  email         String        @unique
  name          String?
  unixUid       Int?          @unique
  unixGid       Int?
  unixUsername  String?       @unique
  role          UserRole      @default(USER)
  createdAt     DateTime      @default(now())
  clusters      ClusterUser[]
  appSessions   AppSession[]
}

model AppSession {
  id          String   @id @default(uuid())
  clusterId   String
  userId      String
  type        String   // "shell" | "jupyter"
  partition   String
  status      String   @default("STARTING") // STARTING | RUNNING | STOPPED | FAILED
  accessUrl   String?  // Jupyter token URL
  createdAt   DateTime @default(now())
  cluster     Cluster  @relation(fields: [clusterId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([clusterId])
  @@index([userId])
}

enum UserRole {
  ADMIN
  USER
}

model ClusterUser {
  id            String            @id @default(uuid())
  userId        String
  clusterId     String
  status        ClusterUserStatus @default(PENDING)
  provisionedAt DateTime?
  user          User              @relation(fields: [userId], references: [id])
  cluster       Cluster           @relation(fields: [clusterId], references: [id])

  @@unique([userId, clusterId])
  @@index([clusterId])
}

enum ClusterUserStatus {
  PENDING
  ACTIVE
  FAILED
  REMOVED
}

// Global key-value settings store (admin-managed).
model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
