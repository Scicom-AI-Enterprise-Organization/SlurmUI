# Database
DATABASE_URL="postgresql://aura:aura@localhost:5432/aura?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Keycloak OIDC
KEYCLOAK_ID="aura-web"
KEYCLOAK_SECRET=""
KEYCLOAK_ISSUER="https://keycloak.scicom.internal/realms/scicom"

# NATS
NATS_URL="nats://localhost:4222"

# FreeIPA
FREEIPA_URL="https://ipa.scicom.internal/ipa"
FREEIPA_USER="admin"
FREEIPA_PASSWORD=""

# Ansible
ANSIBLE_PLAYBOOKS_DIR="/opt/aura/ansible"

# SSH connection multiplexing (OpenSSH ControlMaster). Speeds up polled
# endpoints like /jobs/:id/output by reusing a single SSH connection per
# cluster target instead of handshaking on every call. Only applies to
# non-bastion clusters. 1 = on.
AURA_SSH_MUX=0
# How long the master connection is kept alive after the last use, in
# seconds. Tune higher for high-frequency polls; lower to free sockets.
AURA_SSH_MUX_PERSIST_SEC=600
# Cache eviction TTL on the Node side, in milliseconds. Should be <=
# AURA_SSH_MUX_PERSIST_SEC * 1000 so we don't reference a master that
# OpenSSH has already closed.
AURA_SSH_MUX_TTL_MS=600000
# Pool size per target: up to this many ControlMaster masters are kept
# per (host, user, port, keys) tuple, round-robin'd on each call. One
# master already multiplexes many channels (sshd MaxSessions, default 10),
# so tuning this only helps when you exceed that or want to isolate a
# stuck master from the others.
AURA_SSH_MUX_POOL_SIZE=1

# Bastion-mode shell multiplexing. Keeps one long-lived `ssh -tt` shell
# per bastion target and frames each command with markers, skipping the
# per-call handshake + 1.5s PTY bootstrap. Applies only when the cluster
# is flagged bastion=true. 1 = on.
AURA_BASTION_MUX=0
# Idle TTL for a bastion session (ms). After this period without a call
# the session is closed.
AURA_BASTION_MUX_TTL_MS=600000
# Warm-up deadline for a new session (ms). If the shell doesn't emit its
# ready marker within this window, the session is killed.
AURA_BASTION_MUX_READY_MS=30000
# Per-exec deadline (ms). Command taking longer than this is aborted and
# the session is recycled.
AURA_BASTION_MUX_EXEC_MS=600000
# Pool size per bastion target: up to this many `ssh -tt` shells run in
# parallel for one cluster, each serving one command at a time. Lazily
# grown — a new shell is only opened when all existing ones are busy.
AURA_BASTION_MUX_POOL_SIZE=5
