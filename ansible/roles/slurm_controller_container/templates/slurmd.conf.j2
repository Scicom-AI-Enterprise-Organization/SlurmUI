[program:slurmd]
command=/usr/sbin/slurmd -D
user=root
autostart=true
autorestart=true
startretries=10
stopsignal=TERM
stdout_logfile={{ supervisord_log_dir }}/slurmd.log
stderr_logfile={{ supervisord_log_dir }}/slurmd.err
priority=30
{# slurmd needs slurmctld responding for steady-state checkins; let it
   retry a few times during initial boot rather than crash-looping. #}
startsecs=3
