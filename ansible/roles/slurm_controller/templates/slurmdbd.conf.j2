# Managed by Aura — do not edit manually
AuthType=auth/munge
DbdHost=localhost
DbdPort=6819
SlurmUser={{ slurm_user }}
LogFile={{ slurm_log_dir }}/slurmdbd.log
PidFile=/var/run/slurm/slurmdbd.pid
StorageType=accounting_storage/mysql
StorageHost={{ slurmdbd_storage_host }}
StorageUser={{ slurmdbd_storage_user }}
StoragePass={{ slurmdbd_storage_pass }}
{# slurmdbd's config parser is strict: the db-name key is `StorageLoc`,
   not `StorageDB`. The latter is unrecognised and slurmdbd refuses to
   start with "Could not open/read/parse slurmdbd.conf". #}
StorageLoc={{ slurmdbd_storage_db }}
